# ============================================================
# Optional — Instagram authentication
# Public profiles can be accessed without login.
# Login enables: stories, search, private profiles (if followed)
# ============================================================
# INSTA_ANALYTICS_USERNAME=
# INSTA_ANALYTICS_PASSWORD=

# ============================================================
# Optional — all settings below have sensible defaults
# ============================================================

# # Cache TTL (seconds)
# INSTA_ANALYTICS_CACHE_TTL_POSTS=900
# INSTA_ANALYTICS_CACHE_TTL_PROFILES=86400
# INSTA_ANALYTICS_CACHE_TTL_SEARCH=600

# # Rate limiting
# INSTA_ANALYTICS_MAX_REQUESTS_PER_MINUTE=15
# INSTA_ANALYTICS_DAILY_REQUEST_BUDGET=500

# # Request delay (seconds) — Instagram is aggressive with rate limiting
# INSTA_ANALYTICS_REQUEST_DELAY=4.0
