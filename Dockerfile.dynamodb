FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --extra docker --extra lambda --no-install-project

COPY src/ src/
RUN uv sync --frozen --no-dev --extra docker --extra lambda

EXPOSE 8001

CMD ["uv", "run", "python", "-m", "mcp_insta_analytics", "--http"]
